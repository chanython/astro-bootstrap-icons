{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2024",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "checkJs": true,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true
  },
  "exclude": [
    "dist",
    "node_modules",
    "**/*.config.js",
    "**/*.spec.js",
    "**/*.test.js"
  ]
}
